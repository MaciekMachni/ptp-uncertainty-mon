# ptp4l socket path
ptp4l_socket /var/run/ptp4l

# Poll interval in milliseconds (overrides auto-polling when set)
poll_interval_ms 1000

# Auto-adjust poll interval from PORT_DATA_SET logSyncInterval (0 or 1)
ptp4l_auto_polling 1

# Auto-detect PHC index from PORT_HWCLOCK_NP on ports 1-4 (0 or 1)
phc_auto_detect 1

# PTP domain number (0-255)
ptp4l_domain 0

# Worst-case clock drift in ppb for extrapolating uncertainty (100 ppm)
max_drift_ppb 100000

# Verbose daemon logging (0 or 1)
verbose 0
